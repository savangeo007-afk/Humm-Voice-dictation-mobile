<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pill_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Collapsed state: single logo button -->
    <ImageView
        android:id="@+id/btn_logo"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/pill_bg_collapsed"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:elevation="6dp"
        android:contentDescription="Humm dictation" />

    <!-- Expanded state: 3-button row, hidden by default -->
    <LinearLayout
        android:id="@+id/expanded_row"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/pill_bg_expanded"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:elevation="6dp"
        android:visibility="gone">

        <!-- Cancel button -->
        <ImageView
            android:id="@+id/btn_cancel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_humm_close"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Cancel dictation" />

        <!-- Main mic button (center, slightly larger) -->
        <ImageView
            android:id="@+id/btn_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_humm_mic"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:background="@drawable/pill_bg_collapsed"
            android:contentDescription="Start recording" />

        <!-- Confirm / done button -->
        <ImageView
            android:id="@+id/btn_confirm"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_humm_check"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Confirm and paste text" />

    </LinearLayout>
</FrameLayout>
